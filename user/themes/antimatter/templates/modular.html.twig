{% extends 'partials/base.html.twig' %}

{% set show_onpage_menu = header.onpage_menu == true or header.onpage_menu is null %}
{% macro pageLinkName(text) %}{{ text|lower|replace({' ':'-', 'ą':'a', 'ć':'c', 'ę':'e', 'ł':'l', 'ń':'n', 'ó':'o', 'ś':'s', 'ź':'z', 'ż':'z'}) }}{% endmacro %}

{# NADPISUJEMY NAWIGACJĘ - USUNIĘTO SIDE-NAV #}
{% block header_navigation %}
<style>
    /* --- 1. TWOJE BAZOWE USTAWIENIA I KARTY --- */
    body {
        font-size: 14px !important;
        line-height: 1.4 !important;
        background-color: #f4f4f7 !important;
        /* Dodane tło z poprzedniego kroku */
        background-image: url("{{ url('theme://images/MBackground.jpg') }}") !important;
        background-repeat: no-repeat !important;
        background-attachment: fixed !important;
        background-size: cover !important;
        background-position: center center !important;
    }

    p {
        margin-bottom: 8px !important;
        font-size: 14px !important;
    }

    h1 { font-size: 1.8rem !important; margin: 0 0 10px 0 !important; }
    h2 { font-size: 1.5rem !important; margin: 0 0 8px 0 !important; padding-top: 0 !important; }
    h3 { font-size: 1.2rem !important; margin: 0 0 6px 0 !important; }

    .modular-page { padding-top: 10px !important; }

    /* KONSTRUKCJA KARTY MODULARNEJ */
    .modular-section {
        padding: 5px 0 !important;
        border-bottom: none !important;
    }

    .modular-section .container, 
    .modular-page > .container:first-child {
        background: #ffffff !important;
        padding: 20px 25px !important;
        border-radius: 15px !important;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
        margin-bottom: 15px !important;
    }

    .modular-section .callout {
        padding: 1rem 1rem !important;
        background: transparent !important;
    }

    /* LISTY */
    ul {
        margin: 5px 0 !important;
        padding-left: 25px !important;
    }
    li {
        margin-bottom: 5px !important;
    }

    /* --- 2. NOWA KLASA KONTAKTU (ZDI oraz Internet i Telekomunikacja) --- */
    .contact-card-unified {
        background: #f9f9f9;
        padding: 25px;
        border-radius: 12px;
        /* Pasek boczny na desktopie */
        border-left: 6px solid #0056b3; 
        border-top: none;
        display: flex;
        align-items: center;
        gap: 30px;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .contact-card-unified img {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        flex-shrink: 0;
    }

    .contact-card-unified .info-wrapper {
        display: flex;
        gap: 40px;
        width: 100%;
        flex-wrap: wrap;
    }

    .contact-card-unified .personal-info, 
    .contact-card-unified .company-data {
        flex: 1;
        min-width: 200px;
    }

    /* Linia oddzielająca dane na desktopie */
    .contact-card-unified .company-data {
        border-left: 1px solid #ddd;
        padding-left: 20px;
    }

    /* --- 3. NAGŁÓWEK: TYLKO DLA KOMPUTERÓW (Desktop) --- */
    @media (min-width: 640px) {
        header#header {
            display: flex !important;
            align-items: center !important;
            justify-content: space-between !important;
            padding: 10px 2rem !important;
            min-height: 70px !important;
        }

        #navbar ul.navigation {
            display: flex !important;
            align-items: center !important;
            margin: 0 !important;
        }

        #navbar ul.navigation li a {
            display: block !important;
            line-height: 50px !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
            position: relative !important;
        }

        #navbar ul.navigation li a:before {
            bottom: 0 !important;
            top: auto !important;
            margin: 0 !important;
        }
    }

    /* --- 4. WIDOK MOBILNY (Telefony) --- */
    @media (max-width: 639px) {
        /* Nagłówek i hamburger */
        header#header {
            display: block !important;
            min-height: auto !important;
        }

        #navbar ul.navigation {
            display: none !important;
        }

        /* Kontakt: Pasek na górę i wyśrodkowanie */
        .contact-card-unified {
            flex-direction: column;
            text-align: center;
            border-left: none; /* Usuwamy pasek z boku */
            border-top: 6px solid #0056b3; /* Pasek ląduje na górze */
            padding: 30px 15px;
        }

        .contact-card-unified img {
            margin: 0 auto; /* Środkowanie zdjęcia nad tekstem */
        }

        .contact-card-unified .info-wrapper {
            flex-direction: column;
            gap: 20px;
        }

        .contact-card-unified .company-data {
            border-left: none;
            padding-left: 0;
            border-top: 1px solid #eee;
            padding-top: 15px;
        }

        /* Kompatybilność ze starymi klasami jeśli jeszcze gdzieś zostały */
        .contact-card { 
            flex-direction: column !important; 
            text-align: center !important; 
        }
        .contact-card div { 
            display: flex !important; 
            flex-direction: column !important; 
            align-items: center !important; 
        }
    }
</style>
    
    {{ parent() }}
{% endblock %}

{% block content %}
    <div class="modular-page">
        {# Główna treść strony (jeśli istnieje) #}
        <div class="container">
            {{ page.content|raw }}
        </div>
        
        {# Sekcje modularne jako osobne karty #}
        {% for module in page.collection() %}
            <div id="{{ _self.pageLinkName(module.menu) }}" class="modular-section">
                <div class="container">
                    {{ module.content|raw }}
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block bottom %}
    {{ parent() }}
{% endblock %}