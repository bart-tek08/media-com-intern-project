{% extends 'partials/base.html.twig' %}

{% set show_onpage_menu = header.onpage_menu == true or header.onpage_menu is null %}
{% macro pageLinkName(text) %}{{ text|lower|replace({' ':'-', 'ą':'a', 'ć':'c', 'ę':'e', 'ł':'l', 'ń':'n', 'ó':'o', 'ś':'s', 'ź':'z', 'ż':'z'}) }}{% endmacro %}

{# NADPISUJEMY NAWIGACJĘ TYLKO DLA TEJ STRONY #}
{% block header_navigation %}
    {% if show_onpage_menu %}
        <style>
            /* Menu boczne - desktop */
            .side-nav-fixed {
                position: fixed;
                left: 20px;
                top: 50%;
                transform: translateY(-50%);
                z-index: 9999;
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            .side-nav-fixed a {
                background: #0056b3;
                color: #ffffff !important;
                padding: 15px 25px;
                text-decoration: none !important;
                border-radius: 8px;
                font-weight: 800;
                min-width: 160px;
                text-align: center;
                transition: 0.3s ease;
                font-size: 16px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.3);
                display: block;
            }

            .side-nav-fixed a:hover { 
                background: #1bb3e9 !important; 
                color: #ffffff !important;
                transform: translateX(10px);
            }

            .side-nav-fixed a.active {
                background: #003d80 !important;
            }

            /* UKRYWANIE MENU BOCZNEGO NA URZĄDZENIACH MOBILNYCH */
            @media (max-width: 992px) {
                .side-nav-fixed {
                    display: none !important;
                }
            }

            /* RESPONSYWNE WIZYTÓWKI KONTAKTOWE */
            @media (max-width: 600px) {
                .contact-card {
                    flex-direction: column !important;
                    text-align: center;
                    align-items: center !important;
                }
                .contact-card div {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                }
            }
        </style>

        <nav class="side-nav-fixed">
            {% for module in page.collection() %}
                <a href="#{{ _self.pageLinkName(module.menu) }}">{{ module.menu }}</a>
            {% endfor %}
        </nav>
    {% endif %}
    
    {{ parent() }}
{% endblock %}

{% block content %}
    <div class="modular-page">
        <div class="container" style="padding-top: 50px;">
            {{ page.content|raw }}
        </div>
        
        {% for module in page.collection() %}
            <div id="{{ _self.pageLinkName(module.menu) }}" class="modular-section" style="padding: 80px 0; border-bottom: 1px solid #eee;">
                <div class="container">
                    {{ module.content|raw }}
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block bottom %}
    {{ parent() }}
    <script>
    $(document).ready(function(){
        // Obsługa płynnego przewijania do sekcji
        $('a[href^="#"]').on('click', function(e) {
            var target = $(this.hash);
            if (target.length) {
                e.preventDefault();
                $('html, body').animate({
                    scrollTop: target.offset().top - 20
                }, 800);
            }
        });
    });
    </script>
{% endblock %}