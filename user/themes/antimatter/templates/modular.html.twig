{% extends 'partials/base.html.twig' %}

{% set show_onpage_menu = header.onpage_menu == true or header.onpage_menu is null %}
{% macro pageLinkName(text) %}{{ text|lower|replace({' ':'-', 'ą':'a', 'ć':'c', 'ę':'e', 'ł':'l', 'ń':'n', 'ó':'o', 'ś':'s', 'ź':'z', 'ż':'z'}) }}{% endmacro %}

{# NADPISUJEMY NAWIGACJĘ - USUNIĘTO SIDE-NAV #}
{% block header_navigation %}
    <style>
    /* --- 1. TWOJE BAZOWE USTAWIENIA I KARTY --- */
    body {
        font-size: 14px !important;
        line-height: 1.4 !important;
        background-color: #f4f4f7 !important;
    }

    p {
        margin-bottom: 8px !important;
        font-size: 14px !important;
    }

    h1 { font-size: 1.8rem !important; margin: 0 0 10px 0 !important; }
    h2 { font-size: 1.5rem !important; margin: 0 0 8px 0 !important; padding-top: 0 !important; }
    h3 { font-size: 1.2rem !important; margin: 0 0 6px 0 !important; }

    .modular-page { padding-top: 10px !important; }

    /* KONSTRUKCJA KARTY */
    .modular-section {
        padding: 5px 0 !important;
        border-bottom: none !important;
    }

    .modular-section .container, 
    .modular-page > .container:first-child {
        background: #ffffff !important;
        padding: 20px 25px !important;
        border-radius: 15px !important;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
        margin-bottom: 15px !important;
    }

    /* REDUKCJA PADDINGU Z PLIKU SCSS (_text.scss) */
    .modular-section .callout {
        padding: 1rem 1rem !important;
        background: transparent !important;
    }

    /* LISTY */
    ul {
        margin: 5px 0 !important;
        padding-left: 25px !important;
    }
    li {
        margin-bottom: 5px !important;
    }

    /* --- 2. NAGŁÓWEK: TYLKO DLA KOMPUTERÓW (Desktop) --- */
    @media (min-width: 640px) {
        header#header {
            display: flex !important;
            align-items: center !important;
            justify-content: space-between !important;
            padding: 10px 2rem !important;
            min-height: 70px !important;
        }

        #navbar ul.navigation {
            display: flex !important;
            align-items: center !important;
            margin: 0 !important;
        }

        #navbar ul.navigation li a {
            display: block !important;
            line-height: 50px !important; /* Wysokość Twojego logo */
            padding-top: 0 !important;
            padding-bottom: 0 !important;
            position: relative !important;
        }

        /* NAPRAWA KRESECZEK POD NAPISAMI */
        #navbar ul.navigation li a:before {
            bottom: 0 !important;
            top: auto !important;
            margin: 0 !important;
        }
    }

    /* --- 3. NAGŁÓWEK: TYLKO DLA TELEFONÓW (Mobile) --- */
    @media (max-width: 639px) {
        /* Przywracamy domyślne zachowanie Antimatter dla menu mobilnego */
        header#header {
            display: block !important;
            min-height: auto !important;
        }

        /* Ukrywamy listę tekstową, żeby nie nakładała się na logo */
        #navbar ul.navigation {
            display: none !important;
        }

        .contact-card { 
            flex-direction: column !important; 
            text-align: center !important; 
        }
        .contact-card div { 
            display: flex !important; 
            flex-direction: column !important; 
            align-items: center !important; 
        }
    }
</style>
    
    {{ parent() }}
{% endblock %}

{% block content %}
    <div class="modular-page">
        {# Główna treść strony (jeśli istnieje) #}
        <div class="container">
            {{ page.content|raw }}
        </div>
        
        {# Sekcje modularne jako osobne karty #}
        {% for module in page.collection() %}
            <div id="{{ _self.pageLinkName(module.menu) }}" class="modular-section">
                <div class="container">
                    {{ module.content|raw }}
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block bottom %}
    {{ parent() }}
{% endblock %}